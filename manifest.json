{
  "manifest_version": 3,
  "name": "Web Çevirici (Pro)",
  "version": "1.1",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>"], 
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["tesseract.min.js", "content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}